   417                                  %macro KCLHashStringDJB2 2
   418                                      %assign %%hash 5381
   419                                      %strlen %%len %2
   420                                      %assign %%i 1
   421                                      %rep %%len
   422                                          %substr %%c %2 %%i
   423                                          %assign %%hash ((%%hash * 33) + %%c) & 0xFFFFFFFF 
   424                                          %assign %%i %%i + 1
   425                                      %endrep
   426                                      %define %1 %%hash
   427                                  %endmacro
   428                                  
   429                                  %macro KCLHashStringDJB2_W 2
   430                                      %assign %%hash 5381
   431                                      %strlen %%len %2
   432                                      %assign %%i 1
   433                                      %rep %%len
   434                                          %substr %%c %2 %%i
   435                                          %if %%c >= 'A' && %%c <= 'Z'
   436                                              %assign %%c %%c + 32
   437                                          %endif
   438                                          %assign %%hash ((%%hash * 33) + %%c) & 0xFFFFFFFF
   439                                          %assign %%i %%i + 1
   440                                      %endrep
   441                                      %define %1 %%hash
   442                                  %endmacro
   443                                  
   444                                  %macro XOR_STRING 2
   445                                      %strlen %%len %1
   446                                      %assign %%i 1
   447                                      %rep %%len
   448                                          %substr %%c %1 %%i
   449                                          db %%c ^ %2
   450                                          %assign %%i %%i + 1
   451                                      %endrep
   452                                      db 0 ^ %2                 
   453                                  %endmacro
